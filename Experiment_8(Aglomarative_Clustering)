while True:\n","    clusters = assign_clusters(points, medoids)\n","    new_medoids = update_medoids(clusters)\n","    print(\"Clusters:\", clusters)\n","    print(\"Medoids:\", new_medoids)\n","    print(\"-\" * 30)\n","    if np.array_equal(medoids, new_medoids):\n","        break\n","    medoids = new_medoids\n","print(\"\\nFinal Clusters:\", clusters)\n","print(\"Final Medoids:\", medoids)"]},{"cell_type":"markdown","source":[],"metadata":{"id":"VL7R4LsvuSiE"}}]}